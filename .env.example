USER_NAME=User
# Only "alexa" and "jarvis" can be used as the wake word for now.
WAKE_WORD=alexa

GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=

GEMINI_API_KEY_1=
GEMINI_API_KEY_2=

# If true, every response starts with "Hey <USER_NAME>, ...". If false, it just answers directly.
GREET_USER=true

# The preset instruction sent to the API on every call. Change this to change how Alexa answers.
SYSTEM_INSTRUCTION="You are a fast, minimalist assistant. Explain using layman's terms and avoid bombastic definitions. When defining words, include one example sentence. Answer in 1 or 2 sentences."

# How many seconds the widget stays open after being unpinned (or if it was never pinned) before it auto-closes.
UNPIN_TIMEOUT_SECONDS=5

# Theme the widget opens with: "light" or "dark". Gets updated automatically whenever you switch themes in the widget, so it always remembers the last one you used.
INITIAL_THEME=light

# If true, Alexa starts muted every time the widget opens (you can still unmute it from the widget). If false, it works as usual.
ALWAYS_MUTE=false
